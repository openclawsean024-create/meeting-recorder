{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/auth/register", "dest": "/api/auth.py" },
    { "src": "/api/auth/login", "dest": "/api/auth.py" },
    { "src": "/api/auth/logout", "dest": "/api/auth.py" },
    { "src": "/api/auth/me", "dest": "/api/auth.py" },
    { "src": "/api/user/api-key", "dest": "/api/user.py" },
    { "src": "/api/user/profile", "dest": "/api/user.py" },
    { "src": "/api/user/usage", "dest": "/api/user.py" },
    { "src": "/api/transcribe", "dest": "/api/transcribe.py" },
    { "src": "/api/jobs", "dest": "/api/transcribe.py" },
    { "src": "/api/jobs/(.*)", "dest": "/api/transcribe.py" },
    { "src": "/app", "dest": "/app-page.html" },
    { "src": "/pricing", "dest": "/pricing.html" },
    { "src": "/auth", "dest": "/auth.html" },
    { "src": "/dashboard", "dest": "/dashboard.html" },
    { "src": "/app/api-keys", "dest": "/api-keys.html" },
    { "src": "/landing.html", "dest": "/landing.html" },
    { "src": "/(.*)", "dest": "/landing.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, GET, DELETE, PATCH, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Cookie" }
      ]
    }
  ]
}
